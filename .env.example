APP_NAME=CamTrace API
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret-key-before-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_ALGORITHM=HS256

# For production: set Oracle DSN and disable SQLite fallback
# ORACLE_DSN=oracle+oracledb://camtrace_app:strongpassword@dbhost:1521/?service_name=CAMTRACEPDB
# ALLOW_DEV_SQLITE_FALLBACK=false

# For development: SQLite is used automatically
ORACLE_DSN=
ALLOW_DEV_SQLITE_FALLBACK=true
DEV_SQLITE_URL=sqlite:///./camtrace-dev.db

LAN_IMAGE_ROOT=\\fileserver\camtrace\inspection_photos
CORS_ORIGINS=http://localhost:5173
DEFAULT_MANAGER_OVERRIDE_WINDOW_HOURS=12
REPORT_TIMEZONE=Asia/Kolkata
